# Copy these values into `.env` after running `sh ./utils/generate-keys.sh`.
# This file only contains the project-specific overrides for this app.

SUPABASE_PUBLIC_URL=https://supabase.pure-therapeutic-art-therapy.com
API_EXTERNAL_URL=https://supabase.pure-therapeutic-art-therapy.com

SITE_URL=https://pure-therapeutic-art-therapy.com
ADDITIONAL_REDIRECT_URLS=https://admin.pure-therapeutic-art-therapy.com,https://pure-therapeutic-art-therapy.com

DASHBOARD_USERNAME=supabase

# Keep Kong behind the Plesk reverse proxy.
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Replace with a stable tenant id before first boot.
POOLER_TENANT_ID=pta-prod

# Replace with your real SMTP provider before production cutover.
SMTP_ADMIN_EMAIL=admin@pure-therapeutic-art-therapy.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Pure Therapeutic ART

# This app uses TOTP MFA for admins.
# Uncomment the matching GOTRUE_MFA_* lines in docker-compose.yml if needed.
# MFA_TOTP_ENROLL_ENABLED=true
# MFA_TOTP_VERIFY_ENABLED=true

# The repo currently uses a custom Edge Function.
FUNCTIONS_VERIFY_JWT=false
